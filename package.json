{
  "name": "@electron/symbolicate-mac",
  "version": "0.0.0-development",
  "description": "Symbolicate textual Electron macOS crashes",
  "type": "module",
  "exports": "./dist/index.js",
  "repository": "https://github.com/electron/symbolicate-mac",
  "publishConfig": {
    "provenance": true
  },
  "bin": {
    "electron-symbolicate-mac": "./index.js"
  },
  "files": [
    "index.js",
    "parsing.js"
  ],
  "scripts": {
    "lint": "oxfmt --check . && oxlint",
    "lint:fix": "oxfmt --write . && oxlint --fix",
    "test": "vitest run",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "symbols",
    "breakpad",
    "crash"
  ],
  "contributors": [
    "Jeremy Rose <nornagon@nornagon.net>"
  ],
  "license": "ISC",
  "dependencies": {
    "@indutny/breakpad": "^1.2.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "vitest": "^4.1.2"
  },
  "resolutions": {
    "fsevents": "npm:@electron/fsevents@2.3.3-fork"
  },
  "lint-staged": {
    "*.js": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "*.json": [
      "oxfmt --write"
    ]
  },
  "packageManager": "yarn@4.10.3+sha512.c38cafb5c7bb273f3926d04e55e1d8c9dfa7d9c3ea1f36a4868fa028b9e5f72298f0b7f401ad5eb921749eb012eb1c3bb74bf7503df3ee43fd600d14a018266f"
}
